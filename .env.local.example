# ========================================
# MUSE FRONTEND - Environment Variables Template
# ========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!

# ========================================
# BACKEND API URL
# ========================================
# For local development:
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# For production:
# NEXT_PUBLIC_BACKEND_URL=https://your-backend-url.railway.app

# ========================================
# FRONTEND URL
# ========================================
# For local development:
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# For production:
# NEXT_PUBLIC_FRONTEND_URL=https://your-frontend-url.vercel.app

# ========================================
# GOOGLE OAUTH
# ========================================
# Get from console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ========================================
# LEGACY AUTH (Optional - for backward compatibility)
# ========================================
NEXT_PUBLIC_PUBLISHER_CODE=PUBLISHER@2024
NEXT_PUBLIC_ADMIN_EMAIL=admin@muse.com
NEXT_PUBLIC_ADMIN_PASSWORD=Muse@2024#Secure!
